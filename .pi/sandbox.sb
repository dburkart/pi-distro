;;   * Allow writes under ~/Library/Preferences (cfprefsd)?    add a subpath.
;;   * Restrict network to specific provider hosts?            add deny rules:
;;       (deny network-outbound (remote tcp) (require-not (remote tcp "api.anthropic.com:443")))
;;   * Whitelist executables instead of allow process-exec?   replace
;;     (allow default) for process-exec with (allow process-exec (subpath ...))
