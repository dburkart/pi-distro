;; Default pi sandbox profile.
;; Generated by pi-sandbox. Edit freely; it will not be overwritten.
;;
;; Model: allow everything by default, then deny file writes outside the
;; working directory and temp dirs. See the wrapper script for rationale.

(version 1)
(allow default)

;; ---- File writes ---------------------------------------------------------
;; Deny all writes system-wide, then re-allow the paths we need. Rules are
;; last-match-wins, so order matters: broad deny first, specific allows after.
;; WORK_DIR and TMP_DIR are passed in as sandbox parameters (-D) and MUST be
;; canonical (realpath) paths, because sandbox resolves symlinks before
;; matching (e.g. /var/folders -> /private/var/folders).
(deny file-write* (subpath "/"))
(allow file-write* (subpath (param "WORK_DIR")))
(allow file-write* (subpath "/tmp"))
(allow file-write* (subpath "/private/tmp"))
(allow file-write* (subpath "/var/tmp"))
(allow file-write* (subpath "/private/var/tmp"))
(allow file-write* (subpath (param "TMP_DIR")))
;; /dev is its own filesystem; allow writes there so shell redirections to
;; /dev/null, /dev/tty, etc. keep working. Reads already allowed by default.
(allow file-write* (subpath "/dev"))

